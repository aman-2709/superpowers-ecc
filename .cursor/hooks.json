{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "bash -c 'node \"$(git rev-parse --show-toplevel)/hooks/scripts/session-start.js\"'"
      }
    ],
    "sessionEnd": [
      {
        "command": "bash -c 'node \"$(git rev-parse --show-toplevel)/hooks/scripts/session-end.js\"'"
      },
      {
        "command": "bash -c 'node \"$(git rev-parse --show-toplevel)/hooks/scripts/suggest-compact.js\"'"
      }
    ]
  }
}
